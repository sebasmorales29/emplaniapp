@model Emplaniapp.Abstracciones.ModelosParaUI.TipoRetencionDto

@{
    ViewBag.Title = "Editar Retención";
}

<h2>Editar Retención</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

<div class="form-horizontal">
    <hr />
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
    @Html.HiddenFor(model => model.Id)

    <div class="form-group">
        @Html.LabelFor(model => model.nombreTipoRetencion, "Nombre", htmlAttributes: new { @class = "control-label col-md-2" })
        <div class="col-md-10">
            @Html.EditorFor(model => model.nombreTipoRetencion, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.nombreTipoRetencion, "", new { @class = "text-danger" })
        </div>
    </div>

    <div class="form-group">
        @Html.LabelFor(model => model.porcentajeRetencion, "Porcentaje", htmlAttributes: new { @class = "control-label col-md-2" })
        <div class="col-md-10">
            @Html.EditorFor(model => model.porcentajeRetencion, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.porcentajeRetencion, "", new { @class = "text-danger" })
        </div>
    </div>

    <div class="form-group">
        @Html.LabelFor(model => model.idEstado, "Estado", htmlAttributes: new { @class = "control-label col-md-2" })
        <div class="col-md-10">
            @Html.DropDownListFor(model => model.idEstado, new SelectList(new[]
            {
                new { Value = "1", Text = "Activo" },
                new { Value = "2", Text = "Inactivo" }
            }, "Value", "Text"), new { @class = "form-control" })
            @Html.ValidationMessageFor(model => model.idEstado, "", new { @class = "text-danger" })
        </div>
    </div>

    <div class="form-group" style="margin-top: 25px;">
        <div class="col-md-offset-2 col-md-10">
            <input type="submit" value="Guardar" class="btn btn-primary" />
            <a href="@Url.Action("Index")" class="btn btn-secondary">Cancelar</a>
        </div>
    </div>
</div>
}

<style>
    .btn-secondary {
        margin-left: 10px;
    }
</style>
